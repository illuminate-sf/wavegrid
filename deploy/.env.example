# Copy to .env and fill in. The real .env is gitignored — its only secret is
# the cloud server IP. Both machines read this same format:
#
#   cp deploy/.env.example deploy/.env
#
# Consumed by:
#   deploy/load-env.sh        (mac/linux manual dev)
#   deploy/ecosystem.config.js + deploy/cloud.sh   (cloud server, PM2)
#   deploy/receiver.cmd       (pangolin / Windows receiver)

# ── Shared ───────────────────────────────────────────────────────────
# Address of the cloud server running the grid server. Everything else that
# needs a WebSocket URL is derived from this: ws://CLOUD_IP:SIM_PORT
CLOUD_IP=YOUR_SERVER_IP
SIM_PORT=3000

# Grid geometry — must match across server and receiver.
# GRID=7x7                # COLSxROWS format (auto-derives NUM_CANNONS & GRID_COLUMNS)
# NUM_CANNONS=49          # alternative: set explicitly instead of GRID
# GRID_COLUMNS=7

# ── Cloud server only (server + ui) ──────────────────────────────────
# AUTH_PASSWORD=
# NEXT_PUBLIC_SIMULATOR_URL=   # auto-derived from CLOUD_IP if left unset
# NEXT_PUBLIC_SITE_TITLE=Wavegrid              # shown in browser tab, OG/SMS previews
# NEXT_PUBLIC_SITE_DESCRIPTION=Painting the sky with light

# ── UI port ────────────────────────────────────────────────────────────
# UI_PORT=3003            # main UI port (default: 3003)

# ── Pride show (second instance) ──────────────────────────────────────
# PRIDE_GRID=7x2          # COLSxROWS format (default: 7x2 = 14 cannons)
# PRIDE_SIM_PORT=3001
# PRIDE_UI_PORT=3004
# PRIDE_SITE_TITLE=Wavegrid Pride
# PRIDE_SITE_DESCRIPTION=Painting the sky with light — Pride 7×2

# ── Pangolin / receiver only ─────────────────────────────────────────
# SIMULATOR_URL=               # auto-derived from CLOUD_IP if left unset
# RECEIVER_ALPHA=0.06
# FALLBACK_DELAY=3000
# DEBUG_OSC=1
# DEBUG_UI_PORT=9999             # opens a debug grid UI at http://localhost:9999

# OSC output — pick ONE: a single BEYOND target, or a routing config file.
# BEYOND_HOST=127.0.0.1
# BEYOND_PORT=7001
# BEYOND_GRID_ORDER=row        # "row" or "column"

# Multi-target routing: generate deploy/routing.json with
#   node deploy/gen-config.js   (defaults the IPs below)
# then point the receiver at it.
# ROUTING_CONFIG=deploy/routing.json   # path (relative to repo root) to JSON routing file
# BEYOND_A_HOST=192.168.1.68   # default for gen-config.js (beyond-a machine)
# BEYOND_B_HOST=192.168.1.69   # default for gen-config.js (beyond-b machine)

# ── SSL / Traefik (optional) ──────────────────────────────────────
# MAIN_DOMAIN=main.wavegrid.example.com
# PRIDE_DOMAIN=pride.wavegrid.example.com
# LETSENCRYPT_EMAIL=admin@example.com
