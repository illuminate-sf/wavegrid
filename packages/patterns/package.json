{
  "name": "@wavegrid/patterns",
  "version": "0.1.0",
  "author": "Dan Lynch <pyramation@gmail.com>",
  "description": "QuickJS sandbox pattern engine — evaluates untrusted JS snippets that fill an RGB framebuffer through a ctx API, with host-side safety limiting",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/constructive-io/Illuminate",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/constructive-io/Illuminate"
  },
  "bugs": {
    "url": "https://github.com/constructive-io/Illuminate/issues"
  },
  "scripts": {
    "clean": "makage clean",
    "prepack": "npm run build",
    "build": "makage build",
    "build:dev": "makage build --dev",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --fix",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "wavegrid",
    "quickjs",
    "sandbox",
    "pattern",
    "led",
    "laser",
    "framebuffer"
  ],
  "dependencies": {
    "quickjs-emscripten": "^0.31.0"
  },
  "devDependencies": {
    "makage": "^0.3.0"
  }
}
