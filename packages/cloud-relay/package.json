{
  "name": "@wavegrid/cloud-relay",
  "version": "0.1.0",
  "author": "Dan Lynch <pyramation@gmail.com>",
  "description": "Cloud relay server — login UI, pattern gallery, and command relay to wavegrid agents over WebSocket",
  "main": "index.js",
  "module": "esm/index.js",
  "types": "index.d.ts",
  "homepage": "https://github.com/constructive-io/Illuminate",
  "license": "SEE LICENSE IN LICENSE",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/constructive-io/Illuminate"
  },
  "bugs": {
    "url": "https://github.com/constructive-io/Illuminate/issues"
  },
  "scripts": {
    "clean": "makage clean",
    "prepack": "npm run build",
